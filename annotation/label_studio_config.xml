<View>
  <Header value="SciMem-Update hierarchical relation annotation"/>
  <Text name="source_warning" value="$source_level_update_notice"/>
  <View style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
    <View>
      <Header value="Record A — $left_source"/>
      <Text name="left_claim_text" value="$left_claim"/>
      <Text name="left_locator" value="$left_evidence_locator"/>
    </View>
    <View>
      <Header value="Record B — $right_source"/>
      <Text name="right_claim_text" value="$right_claim"/>
      <Text name="right_locator" value="$right_evidence_locator"/>
    </View>
  </View>

  <Header value="Semantic relation"/>
  <Choices name="semantic_relation" toName="left_claim_text" choice="single" required="true">
    <Choice value="EQUIVALENT"/>
    <Choice value="COMPATIBLE_DISTINCT"/>
    <Choice value="CONTRADICTORY"/>
    <Choice value="UNRELATED"/>
    <Choice value="INSUFFICIENT_CONTEXT"/>
  </Choices>

  <Header value="Scope relation"/>
  <Choices name="scope_relation" toName="left_claim_text" choice="single" required="true">
    <Choice value="SAME_SCOPE"/>
    <Choice value="NARROWER_SCOPE"/>
    <Choice value="BROADER_SCOPE"/>
    <Choice value="DIFFERENT_SCOPE"/>
    <Choice value="UNKNOWN_SCOPE"/>
  </Choices>

  <Header value="Authority relation"/>
  <Choices name="authority_relation" toName="left_claim_text" choice="single" required="true">
    <Choice value="NEWER_MORE_AUTHORITATIVE"/>
    <Choice value="OLDER_MORE_AUTHORITATIVE"/>
    <Choice value="EQUAL_AUTHORITY"/>
    <Choice value="UNRESOLVED"/>
    <Choice value="NOT_APPLICABLE"/>
  </Choices>

  <Header value="Evidence sufficiency"/>
  <Choices name="evidence_sufficiency" toName="left_claim_text" choice="single" required="true">
    <Choice value="SUFFICIENT"/>
    <Choice value="PARTIAL"/>
    <Choice value="INSUFFICIENT"/>
  </Choices>

  <Header value="Disagreement reason (choose all that apply after adjudication is requested)"/>
  <Choices name="disagreement_reasons" toName="left_claim_text" choice="multiple">
    <Choice value="AMBIGUOUS_CLAIM_BOUNDARY"/>
    <Choice value="ENTITY_RESOLUTION"/>
    <Choice value="RELATION_INTERPRETATION"/>
    <Choice value="SCOPE_GRANULARITY"/>
    <Choice value="TEMPORAL_ORDER"/>
    <Choice value="AUTHORITY_UNCLEAR"/>
    <Choice value="EVIDENCE_MISSING"/>
    <Choice value="SOURCE_STATUS_ONLY"/>
    <Choice value="ANNOTATION_ERROR"/>
  </Choices>
  <TextArea name="evidence_note" toName="left_claim_text" rows="4"
            placeholder="Quote or cite only the visible evidence needed to justify the labels."/>
  <TextArea name="adjudication_note" toName="left_claim_text" rows="3"
            placeholder="Optional note for adjudication; do not propose a memory operation."/>
</View>
