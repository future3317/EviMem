# DeepSeek API key placeholder for the adjudication pipeline.
# The runner reads this local, gitignored .env file only when the process
# environment does not already define DEEPSEEK_API_KEY. Alternatively set it
# for the current PowerShell session with:
#   $env:DEEPSEEK_API_KEY = '<rotated key>'
# Never put a real key in this file or commit it.
DEEPSEEK_API_KEY=
